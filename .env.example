# ── Environment ───────────────────────────────────────────────
ENV=development

# ── Server ────────────────────────────────────────────────────
SERVER__PORT=8080
SERVER__READ_TIMEOUT=15s
SERVER__WRITE_TIMEOUT=15s
SERVER__IDLE_TIMEOUT=60s

# ── Database ──────────────────────────────────────────────────
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__USER=fairqueue
DATABASE__PASSWORD=fairqueue
DATABASE__NAME=fairqueue
DATABASE__SSL_MODE=disable
DATABASE__MAX_OPEN_CONNS=25
DATABASE__MAX_IDLE_CONNS=5
DATABASE__CONN_MAX_LIFETIME=15m
DATABASE__CONN_MAX_IDLE_TIME=5m

# ── Redis ─────────────────────────────────────────────────────
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__PASSWORD=
REDIS__DB=0

# ── Auth ──────────────────────────────────────────────────────
# Must be at least 32 characters. Use: openssl rand -hex 32
AUTH__TOKEN_SECRET=replace-this-with-a-random-secret-at-least-32-chars
AUTH__TOKEN_TTL=5m

# ── Paystack ──────────────────────────────────────────────────
PAYSTACK__SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK__WEBHOOK_SECRET=replace-with-your-paystack-webhook-secret
PAYSTACK__BASE_URL=https://api.paystack.co

# ── Gateway retry ─────────────────────────────────────────────
GATEWAYRETRY__MAX_ATTEMPTS=3
GATEWAYRETRY__BASE_DELAY=500ms
GATEWAYRETRY__MAX_DELAY=5s

# ── Workers ───────────────────────────────────────────────────
WORKERS__ADMISSION__INTERVAL=5s
WORKERS__ADMISSION__BATCH_SIZE=50

WORKERS__EXPIRY__INTERVAL=30s
WORKERS__EXPIRY__BATCH_SIZE=100

WORKERS__RECONCILIATION__INTERVAL=30s
WORKERS__RECONCILIATION__STALE_PAYMENT_AGE=10m
WORKERS__RECONCILIATION__STALE_QUEUE_ENTRY_AGE=2h

# ── Logger ────────────────────────────────────────────────────
# Options: debug, info, warn, error
LOGGER__LEVEL=info
